pipeline{
    agent any
    tools{
        jdk 'jdk'
        nodejs 'node17'
    }
    environment {
        SCANNER_HOME=tool 'sonar-scanner'
    }
    stages {
        stage('clean workspace'){
            steps{
                cleanWs()
            }
        }
        stage('Checkout from Git'){
            steps{
                git branch: 'main', url: 'https://github.com/Aseemakram19/amazon-prime-video-kubernetes.git'
            }
        }
        stage("Sonarqube Analysis "){
            steps{
                withSonarQubeEnv('SonarQube') {					
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=amazon-prime-video \
                    -Dsonar.projectKey=amazon-prime-video '''
                }
									//('SonarQube') --> ye name jo apne system me rakha hoga vohi use krna hai. 
									//Manage Jenkins -> System -> SonarQube Servers -> Name: SonarQube   ← YEH WALA NAME HAI!. And KOI bhi naam rakh sakte ho
									//Jenkins Tool Name = tumhari marzi ka koi bhi naam
									//Binary File Name  = hamesha fixed "sonar-scanner" hoga
									//Tool ka naam sirf Jenkins ke andar identify karne ke liye hota hai.
									//Tumne apne phone ka naam rakha  →  "Mera Phone"
									//Lekin company ka actual naam    →  "Samsung Galaxy S23
									//Tum apne ghar mein "Mera Phone" bologe
									//Lekin shop pe jaake "Mera Phone" maango toh nahi milega ❌
									//Wahan "Samsung Galaxy S23" maangna padega ✅
            }
        }
        stage("quality gate"){
           steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'Sonar-token' 
                }
            } 
									//Quality Gate ek pass/fail criteria hota hai jo SonarQube set karta hai!
										//Tumhara code SonarQube pe gaya
										//SonarQube ne analyze kiya
										//Ab Quality Gate check karta hai:
										//✅ PASSED → Pipeline aage badh sakti hai
										//❌ FAILED → Pipeline rok do / warning do
										//Quality Gate kya check karta hai:
										//*********************************
										//Criteria						Example
										//Code Coverage					80% se kam nahi hona chahiye
										//Bugs							0 critical bugs
										//Vulnerabilities					0 critical security issues
										//Code Smells						100 se kam
										//Duplications					3% se kam
        }
        stage('Install Dependencies') {
            steps {
                sh "npm install"
            }
        }        
        stage('TRIVY FS SCAN') {
            steps {
                sh "trivy fs . > trivyfs.txt"
            }
													//difference b/w fs scan and image scan:
														//trivy fs — Sirf tumhara code/dependencies scan karta hai
														//**********************************************************
														//tumhara code
											    		//	├── package.json        ← scan
											    		//	├── requirements.txt    ← scan
											    		//	├── source code files   ← scan
											    		//	└── config files        ← scan
														//trivy image — Puri Docker image scan karta hai
														//**********************************************
														//Docker Image
											    		//	  ├── Base OS (ubuntu:20.04)     ← NEW - yeh fs me nahi tha
														//    │     ├── openssl vulnerability
														//    │     ├── libc vulnerability
														//    │     └── kernel packages
														//    ├── Runtime (node:18)          ← NEW - yeh fs me nahi tha
														//    │     └── npm vulnerabilities
														//    └── tumhara code               ← same jo fs me tha
											
        }
        stage("Docker Build & Push"){
            steps{
                script{
                   withDockerRegistry(credentialsId: 'docker', toolName: 'docker'){   
                       sh "docker build -t amazon-prime-video ."
                       sh "docker tag amazon-prime-video aseemakram19/amazon-prime-video:latest "
                       sh "docker push aseemakram19/amazon-prime-video:latest "
                    }
                }
            }
        }
		stage('Docker Scout Image') {
            steps {
                script{
                   withDockerRegistry(credentialsId: 'docker', toolName: 'docker'){
                       sh 'docker-scout quickview aseemakram19/amazon-prime-video:latest'
                       sh 'docker-scout cves aseemakram19/amazon-prime-video:latest'
                       sh 'docker-scout recommendations aseemakram19/amazon-prime-video:latest'
                   }
                }
            }
        }
										//Docker Scout alag perspective deta hai — Trivy se better recommendations aur Docker Hub integration hoti hai!
										//-------------------------------------------------------------------------------------------------------------
										//Trivy vs Docker Scout difference:
										//*********************************
																							//TrivyDocker 					Scout
										//Vulnerabilities dhundta hai							✅							  ✅
										//Fix suggestions deta hai								❌ Limited					  ✅ Detailed
										//Better base image suggest karta hai					❌							  ✅
										//Docker Hub se directly integrate						❌							  ✅
										//SBOM (software bill of materials)						❌							  ✅
										//================================
										//Trivy sirf batata hai:
										//CRITICAL CVE-2023-1234 found in openssl 1.1.1
										//❌ Fix nahi batata
										//❌ Better image suggest nahi karta
										//Docker Scout batata hai:
										//CRITICAL CVE-2023-1234 found in openssl 1.1.1
										//✅ Update to openssl 1.1.2 to fix this
										//✅ Use node:18-alpine instead of node:18
										//(alpine me 10 vulnerabilities kam hain)
										//--------------------------------------------
										//quickview ka matlab:
										//+++++++++
										//groovydocker-scout quickview armcool004/amazon-app-con
										//``
										//`
										//Summary deta hai ek nazar mein
										//Image: armcool004/amazon-app-con
										//CRITICAL : 2
										//HIGH : 5
										//MEDIUM : 10
										//LOW : 3
										//Fast overview - details nahi
										//*****************************************
										//cves ka matlab:
										//+++++
										//groovydocker-scout cves armcool004/amazon-app-con
										//` `
										//CVE = Common Vulnerabilities and Exposures
										//Har vulnerability ki detail deta hai
										//CVE-2023-1234
										//Package : openssl 1.1.1
										//Severity : CRITICAL
										//Fix : upgrade to 1.1.2
										//CVE-2023-5678
										//Package : libc 2.31
										//Severity : HIGH
										//Fix : upgrade to 2.35
										//*****************************************
										//recommendations ka matlab:
										//+++++++++++++++
										//groovydocker-scout recommendations armcool004/amazon-app-con
										//` `
										//Better base image suggest karta hai
										//Current image : node:18 (15 critical CVEs)
										//Recommended : node:18-alpine (2 critical CVEs) ← use this
										//Alternative : node:18-slim (5 critical CVEs)
										//Yeh Trivy kabhi nahi batata ❌
										//`
										//Poora pipeline flow samjho: ``
										//trivy fs → tumhara source code check karo
										//↓
										//SonarQube → code quality check karo
										//↓
										//Quality Gate → pass/fail decision lo
										//↓
										//Docker Build → image banao
										//↓
										//trivy image → image ki vulnerabilities dhundo
										//↓
										//Docker Scout → better fix aur recommendations lo ✅
										//↓
										//Docker Push → safe image push karo

        stage("TRIVY-docker-images"){
            steps{
                sh "trivy image aseemakram19/amazon-prime-video:latest > trivyimage.txt" 
            }
        }
        stage('App Deploy to Docker container'){
            steps{
                sh 'docker run -d --name amazon-prime-video -p 3000:3000 aseemakram19/amazon-prime-video:latest'
            }
        }

    }
    post {
        always {
            script {
                def buildStatus = currentBuild.currentResult
                def buildUser = currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')[0]?.userId ?: 'Github User'
                emailext (
                    subject: "Pipeline ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body: """
                    <p>This is a Jenkins amazon-prime-video CICD pipeline status.</p>
                    <p>Project: ${env.JOB_NAME}</p>
                    <p>Build Number: ${env.BUILD_NUMBER}</p>
                    <p>Build Status: ${buildStatus}</p>
                    <p>Started by: ${buildUser}</p>
                    <p>Build URL: <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>""",
                    to: 'intraday001@gmail.com',
                    from: 'intraday001@gmail.com',
                    replyTo: 'intraday001@gmail.com',
                    mimeType: 'text/html',
                    attachmentsPattern: '**/trivyFSscan.txt,**/trivydocimagescan.txt'
                )
            }
        }
    }
		//hum extended email and normal email kyu use krte hain?
		//--------------------------------------------------------
			//Normal Email — Basic notifications:
			//***********************************
			//Manage Jenkins → Configure System → Email Notification
			//✅ Sirf basic email bhejta hai
			//✅ Build pass/fail pe notify karta hai
			//❌ HTML email nahi bana sakta
			//❌ Attachments nahi de sakta
			//❌ Conditional logic nahi hoti
			//❌ Custom template nahi bana sakta
													//Basic Email setup:
													//--------------------
														//Email Extension Plugin
														//xsuc kxeb xcvk xqkf
														//1. Basic Email Notification
														//SMTP Server: smtp.gmail.com
														//Email Suffix: @gmail.com (default user email domain)
														//SMTP Authentication: Enabled
														//Username: Your Gmail address
														//Password: Your Gmail password or App Password (for 2-factor authentication)
														//Use TLS: Checked
														//SMTP Port: 587 (for tls)
														//Reply-To Address: Your email address
														//Charset: UTF-8
			//Extended Email — Advanced notifications:
			//****************************************
				//Manage Jenkins → Configure System → Extended E-mail Notification
				//✅ HTML email bana sakta hai
				//✅ Attachments de sakta hai (trivy report, logs)
				//✅ Conditional logic hoti hai
				//✅ Custom templates bana sakta hai
				//✅ Multiple recipients alag alag conditions pe
				//✅ Build logs attach kar sakta hai
													//Extended Email Settings:
													//--------------------------
														//SMTP Server: smtp.gmail.com
														//SMTP Port: 465 (for ssl) 
														//Use SSL: Checked
														//in Advanced section:
															//Default user e-mail suffix: @gmail.com
														//Credentials:
														//and also have to give the "Credentials" --> manage jenkins -> security -> add credentials -> gmail id and password you get 															//from 2 step authentication.
														//then simply select the Credentials you add in extended email.

    }

}
